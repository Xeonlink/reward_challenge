{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx next *)",
      "Bash(npx tsc *)",
      "PowerShell(try { $r = Invoke-WebRequest -Uri http://localhost:3000 -TimeoutSec 6 -UseBasicParsing; \"HTTP $\\($r.StatusCode\\)\" } catch { \"error: $_\" })",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "Bash(git remote *)"
    ]
  }
}
