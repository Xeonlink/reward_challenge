{
  "name": "reward-slots",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "tsc": "tsc --noEmit",
    "build": "next build",
    "start": "next start -p 4000",
    "prepare": "panda codegen",
    "format": "prettier --write .",
