    "docker:build": "docker buildx build --platform linux/amd64 -t registry.ohjimin.com/$npm_package_name:$npm_package_version .",
    "docker:push": "docker push registry.ohjimin.com/$npm_package_name:$npm_package_version"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "es-toolkit": "^1.47.0",
    "immer": "^11.1.8",
    "next": "16.2.9",
    "radix-ui": "^1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.11.0",
    "@playwright/test": "^1.60.0",
    "@svgr/webpack": "^8.1.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@xeonlink/prettier-plugin-organize-attributes": "^1.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8",
    "prettier": "^3.8.4",
    "prettier-plugin-curly": "^0.4.1",
    "prettier-plugin-organize-imports": "^4.3.0",
